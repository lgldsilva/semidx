# Local pre-push coverage floor (statement-weighted). CI (.github/workflows/ci.yml)
# instead averages per-function % over all internal|pkg — a different metric that
# stays ≥90% even when large integration packages (store/server/webadmin) sit
# lower on statement coverage. Scope the local floor to packages with strong
# unit tests; the full `go test ./... -race` suite still runs unconditionally.
COVER_PKGS="./internal/usage/... ./internal/gitmeta/... ./internal/chunker/... ./internal/privacy/... ./internal/keyword/... ./internal/observ/... ./internal/search/... ./internal/searchtargets/... ./internal/localstore/... ./pkg/client/..."
COVERAGE_MIN=90
