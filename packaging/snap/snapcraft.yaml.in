# Generated by scripts/render-package-manifests.sh.
# semidx is a developer/server tool that indexes arbitrary local repositories.
# Classic confinement is intentional: strict confinement would make normal
# repository indexing and user-selected document paths unusable.
name: semidx
base: core24
version: '@VERSION@'
summary: Self-hosted semantic code search
description: |
  semidx indexes repositories and documents, then provides semantic search
  through its CLI, HTTP server, and MCP integration.
grade: stable
confinement: classic

platforms:
  @SNAP_ARCH@:
    build-on: [@SNAP_ARCH@]
    build-for: [@SNAP_ARCH@]

parts:
  semidx:
    plugin: dump
    source: https://github.com/lgldsilva/semidx/releases/download/v@VERSION@/semidx_@VERSION@_linux_@SNAP_ARCH@.tar.gz
    source-checksum: sha256/@SNAP_SHA256@
    organize:
      semidx: bin/semidx

apps:
  semidx:
    command: bin/semidx
