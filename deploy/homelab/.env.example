# semidx homelab instance — copy to `.env` next to docker-compose.yml and fill in.
# The file holds secrets: keep it 0600 and never commit the real .env.

# --- Postgres (internal only; no published port) ---
POSTGRES_USER=semidx
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=semidx

# --- semidx server ---
# The published image + the API/UI port (the only ingress).
SEMIDX_IMAGE=gitea.raspberrypi.lan/lgldsilva/semidx:latest
SEMIDX_PORT=8080
# The host's Ollama (GPU). Leave the default if Ollama runs on the host.
SEMIDX_OLLAMA_URL=http://host.docker.internal:11434
GOMEMLIMIT=900MiB

# First-boot bootstrap (used only while the DB is empty):
#   - a fixed admin API token for the CLI (leave empty to have one generated and
#     printed in the logs once);
#   - the admin web-UI password.
SEMIDX_BOOTSTRAP_TOKEN=
SEMIDX_BOOTSTRAP_ADMIN_USER=admin
SEMIDX_BOOTSTRAP_ADMIN_PASSWORD=change-me
# HS256 secret to enable revocable JWT control tokens (optional).
SEMIDX_JWT_SECRET=
# Set false only when serving the /admin UI over plain HTTP on the LAN.
SEMIDX_COOKIE_SECURE=true

# --- Optional cloud embedding providers (chain falls back to local Ollama) ---
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
