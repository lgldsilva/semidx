# An "agent workstation" image for the MCP test harness: semidx + the MCP probe
# + real coding-agent CLIs + the harness scripts. Build context is the repo root:
#   docker build -f deploy/agentics-test/Dockerfile.agents -t semidx-agents .

# Stage 1 — build semidx and the MCP probe as static binaries.
FROM golang:1.26.5 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/semidx ./cmd/semidx \
 && CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/mcp-probe ./deploy/agentics-test/mcp-probe

# Stage 2 — a Node base (agent CLIs ship as npm packages) with git + bash.
FROM node:22-bookworm-slim
RUN apt-get update \
 && apt-get install -y --no-install-recommends git ca-certificates bash \
 && rm -rf /var/lib/apt/lists/*

# Coding-agent CLIs ("os agentics"). Best-effort: the harness verifies EVERY
# supported client's config via schema regardless of which CLIs installed, so a
# registry hiccup never makes the image useless — the native `claude mcp list`
# and real-agent checks simply SKIP. Add more agents here as they publish CLIs.
RUN npm install -g @anthropic-ai/claude-code @google/gemini-cli || true

COPY --from=build /out/semidx /out/mcp-probe /usr/local/bin/
COPY deploy/agentics-test/ /harness/
RUN chmod +x /harness/run.sh /harness/lib.sh

RUN useradd -m tester
USER tester
ENV HOME=/home/tester PROBE=mcp-probe FIXTURE=/harness/testdata/fixture
WORKDIR /home/tester

# Default: the always-hermetic no-Postgres variations. Override the arg for the
# server variation (compose sets it), e.g. `docker compose run agents server`.
ENTRYPOINT ["/harness/run.sh"]
CMD ["all"]
