#!/usr/bin/env bash
# Semantic grep wrapper — auto-detects the project name from the cwd.
# Usage: sgrep "query" [top_k]
#
# Install: cp scripts/sgrep ~/bin/sgrep && chmod +x ~/bin/sgrep
#
# Configuration comes from the environment or from ~/.config/semidx/env
# (a plain shell file you own, chmod 600), e.g.:
#   export GEMINI_API_KEY=...
#   export SEMIDX_BIN=/path/to/semantic-indexer-poc
# No secrets live in this script.
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: sgrep <query> [top_k]" >&2
  exit 1
fi

QUERY="$1"
TOP_K="${2:-5}"

CONF="$HOME/.config/semidx/env"
# shellcheck disable=SC1090
[ -f "$CONF" ] && . "$CONF"

BIN="${SEMIDX_BIN:-$(command -v semantic-indexer-poc || true)}"
if [ -z "$BIN" ] || [ ! -x "$BIN" ]; then
  echo "sgrep: indexer binary not found — set SEMIDX_BIN in $CONF or add it to PATH" >&2
  exit 2
fi

PROJECT=$(basename "$(pwd)")

exec "$BIN" sgrep -project "$PROJECT" -query "$QUERY" -top-k "$TOP_K"
