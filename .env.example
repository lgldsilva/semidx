# semidx environment variables reference
# =======================================
# Copy this file to .env, uncomment and adjust the values you need.
# Real environment variables take precedence over .env file values.
#
# SECRETS: variables marked (secret) are masked in `semidx config list`
#          and written with 0600 permissions. Keep them out of version control.
#
# See docs/self-hosting.md and docs/api.md for detailed documentation.

# ── Storage backend ──────────────────────────────────────────────────────────
# Pick ONE backend. Runtime precedence: remote > Postgres (configured) > SQLite > Postgres (default).
# SEMIDX_DB_DSN=postgres://semidx:changeme@localhost:55432/semidx?sslmode=disable   # (secret) PostgreSQL/pgvector DSN
# SEMIDX_DB_PASSWORD=changeme                                                        # DB password used by docker-compose to build the DSN
# SEMIDX_LOCAL_INDEX=                                                               # Path to local SQLite index, or 1/true for default location

# ── Embedding mode ───────────────────────────────────────────────────────────
# SEMIDX_EMBED_MODE=      # Set to "none" for keyword-only indexing (no embeddings)

# ── Embedding providers ──────────────────────────────────────────────────────
# Local Ollama (always-present fallback)
# SEMIDX_OLLAMA_URL=http://localhost:11434         # Local Ollama endpoint
# SEMIDX_OLLAMA_URLS=                              # Comma-separated Ollama URLs for parallel pooling (overrides SEMIDX_OLLAMA_URL)

# Google Gemini
# GEMINI_API_KEY=                                  # (secret) Gemini embedding key
# SEMIDX_GEMINI_BASE_URL=                          # Gemini API base URL override

# Groq
# GROQ_API_KEY=                                    # (secret) Groq embedding key
# SEMIDX_GROQ_BASE_URL=                            # Groq API base URL override

# OpenRouter
# OPENROUTER_API_KEY=                              # (secret) OpenRouter embedding key
# SEMIDX_OPENROUTER_BASE_URL=                      # OpenRouter API base URL override

# Ollama Cloud
# OLLAMA_CLOUD_API_KEY=                            # (secret) Ollama Cloud embedding key
# SEMIDX_OLLAMA_CLOUD_BASE_URL=                    # Ollama Cloud API base URL override

# Custom provider (prepended to the chain)
# EMBED_PROVIDER=                                  # "openai" or "ollama"
# EMBED_ENDPOINT=                                  # Custom provider endpoint URL
# EMBED_API_KEY=                                   # (secret) Custom provider API key
# EMBED_PRIVACY=false                              # true = force local-only providers

# ── Indexing & extraction ────────────────────────────────────────────────────
# SEMIDX_INDEX_WORKERS=4             # Concurrent index workers (positive int)
# SEMIDX_EMBED_BATCH_SIZE=8          # Texts per embedding API call (positive int)
# SEMIDX_MAX_FILE_SIZE=1048576       # Max file size in bytes (default 1 MB)
# SEMIDX_MAX_CHUNKS_PER_FILE=32      # Max chunks per file (positive int)
# SEMIDX_JAVA_DECOMPILER=            # External Java decompiler command for .class inside JARs

# ── Server (semidx serve) ────────────────────────────────────────────────────
# SEMIDX_LISTEN_ADDR=:8080                  # HTTP API bind address
# SEMIDX_DATA_DIR=/var/lib/semidx           # Git clone directory for server-side sync
# SEMIDX_BOOTSTRAP_TOKEN=                   # (secret) Fixed bootstrap admin token
# SEMIDX_BOOTSTRAP_ADMIN_USER=admin         # Web-admin bootstrap username
# SEMIDX_BOOTSTRAP_ADMIN_PASSWORD=          # (secret) Web-admin bootstrap password
# SEMIDX_COOKIE_SECURE=true                 # Secure flag on admin cookies (false only for plain HTTP)
# SEMIDX_JWT_SECRET=                        # (secret) HS256 key for JWT control tokens
# SEMIDX_CSRF_KEY=                          # (secret) HMAC key for CSRF tokens (persistent across restarts)
# SEMIDX_GIT_ALLOW_FILE=false               # Allow file:// git URLs for server-side git sync
# SEMIDX_GIT_SSL_NO_VERIFY=false            # true = skip TLS verify on server-side git clone/pull (self-signed Gitea)
# SEMIDX_GIT_TOKEN=                         # (secret) Token for private HTTPS clones (falls back to SEMIDX_GITHUB_TOKEN)
# SEMIDX_GIT_USER=                          # Basic-auth user for SEMIDX_GIT_TOKEN (default x-access-token)
# SEMIDX_METRICS_TOKEN=                     # (secret) Bearer token for GET /metrics when set

# ── CLI / standalone (not used by the server) ────────────────────────────────
# SEMIDX_SERVER_URL=                        # Override the server URL (remote-backend mode)
# SEMIDX_TOKEN=                             # (secret) Override the bearer token
# SEMIDX_DEFAULT_PROJECT=                   # Default project for search/sgrep

# ── Self-update (semidx upgrade) ─────────────────────────────────────────────
# SEMIDX_UPDATE_API=                        # Releases API base URL
# SEMIDX_UPDATE_URL=                        # Release download base URL
# SEMIDX_UPDATE_TOKEN=                      # (secret) Token for private release host
# SEMIDX_INSECURE=                          # 1 = skip TLS verification for update downloads

# ── Runtime ──────────────────────────────────────────────────────────────────
# GOMEMLIMIT=                               # Go soft heap limit (e.g. 900MiB)

# ── Legacy aliases (supported, prefer the SEMIDX_ variant) ───────────────────
# OLLAMA_URL=http://localhost:11434          # Legacy alias for SEMIDX_OLLAMA_URL
