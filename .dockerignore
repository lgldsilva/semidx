.git
.github
semidx
semantic-indexer-poc
dist
coverage.out
coverage.html
*.test
docs
deploy
# …but the agentics test image (built from the repo root) needs its harness files.
# This only widens the build context; the final server image copies just the binary.
!deploy/agentics-test

# Never let local secrets reach the build context (the build stage does COPY . .).
# Listed AFTER the deploy re-include so .env files are excluded even under it.
.env
.env.*
**/.env
**/*.env
*.pem
*.key
